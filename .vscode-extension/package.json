{
  "name": "notrium-data-syntax",
  "displayName": "Notrium Data Highlighter",
  "version": "1.0.0",
  "publisher": "vanjo",
  "engines": {
    "vscode": "^1.50.0"
  },
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "notrium",
        "aliases": [
          "Notrium Data"
        ],
        "extensions": [
          ".dat"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "notrium",
        "scopeName": "source.notrium",
        "path": "./syntaxes/notrium.tmLanguage.json"
      }
    ],
    "activationEvents": [
      "onLanguage:notrium"
    ],
    "main": "./out/extension.js"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/vscode": "^1.109.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "npx tsc"
  }
}
