	-1.000000;//time to delete object in milliseconds, -1=don't delete
	4;//trigger event by 0=player click, 1=player near, 2=near or click, 3=map creation (try to avoid any creature specific effects when using this, also does not check conditions), 4=interval parameter1
		100;//trigger event parameter1
	0;//show help text for conditions
	begin_effects_block;
		none;//event text----------------------------------------------------------------------------WAKE UP IF ENERGY BAR IS FULL //TODO: HEALING
			wake_up_yawn.wav;//sound, none for nothing
			1;//vanishes after event, 0=no, but cannot be reused, 1=vanishes, 2=no, and can be reused
			begin_conditions;
				44;//condition-----------------------RANDOM CHANCE
					6.000000;//condition parameter0
					100.000000;//condition parameter1
			end_conditions;
			begin_effects;
				29;//effect number------------------------------Run Script "WAKE UP PLAYER"
					203.000000;//parameter1
					1.000000;//parameter2
					0.000000;//parameter3
					0.000000;//parameter4
			end_effects;
		none;//event text----------------------------------------------------------------------------TICK SLEEPING EFFECT
			none;//sound, none for nothing
			2;//vanishes after event, 0=no, but cannot be reused, 1=vanishes, 2=no, and can be reused
			begin_conditions;
			end_conditions;
			begin_effects;
				4;//effect number------------------------------RAISE ENERGY BAR
					0.025000;//parameter1
					0.000000;//parameter2
					6.000000;//parameter3
					0.000000;//parameter4
				4;//effect number------------------------------SLOW DOWN HYDRATION
					0.003500;//parameter1
					0.000000;//parameter2
					1.000000;//parameter3
					0.000000;//parameter4
				4;//effect number------------------------------SLOW DOWN NUTRITION
					0.003500;//parameter1
					0.000000;//parameter2
					5.000000;//parameter3
					0.000000;//parameter4
				1;//effect number------------------------------STOP PLAYER MOVING
					150.000000;//parameter1
					-1.000000;//parameter2
					0.000000;//parameter3
					1.000000;//parameter4
			end_effects;
		none;//event text----------------------------------------------------------------------------RANDOM CHANCE SNORE
			none;//sound, none for nothing
			2;//vanishes after event, 0=no, but cannot be reused, 1=vanishes, 2=no, and can be reused
			begin_conditions;
				8;//condition-----------------------RANDOM CHANCE
					250.000000;//condition parameter0
					0.000000;//condition parameter1
			end_conditions;
			begin_effects;
				14;//effect number------------------------------PLAY SOUND (SNORE)
					4.000000;//parameter1
					0.200000;//parameter2
					0.000000;//parameter3
					0.000000;//parameter4
			end_effects;
		none;//event text----------------------------------------------------------------------------RANDOM CHANCE SLEEP EFFECT
			none;//sound, none for nothing
			2;//vanishes after event, 0=no, but cannot be reused, 1=vanishes, 2=no, and can be reused
			begin_conditions;
				8;//condition-----------------------RANDOM CHANCE
					10.000000;//condition parameter0
					0.000000;//condition parameter1
			end_conditions;
			begin_effects;
				27;//effect number------------------------------DROP SLEEPING EFFECT LIGHT
					1.000000;//parameter1
					500.000000;//parameter2
					0.300000;//parameter3
					0.500000;//parameter4
			end_effects;
		none;//event text----------------------------------------------------------------------------IF PLAYER MOVED, CANCEL
			click2.wav;//sound, none for nothing
			1;//vanishes after event, 0=no, but cannot be reused, 1=vanishes, 2=no, and can be reused
			begin_conditions;
				15;//condition-----------------------If Player Moved
					25.000000;//condition parameter0
					1.000000;//condition parameter1
			end_conditions;
			begin_effects;
				29;//effect number------------------------------Run Script "WAKE UP PLAYER"
					203.000000;//parameter1
					1.000000;//parameter2
					0.000000;//parameter3
					0.000000;//parameter4
			end_effects;
	end_effects_block;
